{
  "info": {
    "name": "MBDS Pizza - Ingredients CRUD",
    "description": "CRUD requests for ingredients. Run the auth collection first so {{token}} is available.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Ingredient",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/ingredients",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "ingredients"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Mozzarella\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Ingredient created', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "var response = pm.response.json();",
              "pm.environment.set('ingredientId', response.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Get All Ingredients",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/ingredients",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "ingredients"
          ]
        }
      }
    },
    {
      "name": "Get Ingredient By Id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/ingredients/{{ingredientId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "ingredients",
            "{{ingredientId}}"
          ]
        }
      }
    },
    {
      "name": "Update Ingredient",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/ingredients/{{ingredientId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "ingredients",
            "{{ingredientId}}"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Mozzarella Updated\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      }
    },
    {
      "name": "Delete Ingredient",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/ingredients/{{ingredientId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "ingredients",
            "{{ingredientId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Ingredient deleted', function () {",
              "  pm.response.to.have.status(204);",
              "});",
              "",
              "pm.environment.unset('ingredientId');"
            ]
          }
        }
      ]
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  }
}