{
  "info": {
    "name": "MBDS Pizza - Full CRUD Flow",
    "description": "End-to-end flow: login, categories CRUD, ingredients CRUD, pizzas CRUD, then cleanup. Safe to run from the Postman Collection Runner.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login as Admin",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"+261000000000\",\n  \"password\": \"1234\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "auth": {
          "type": "noauth"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Login succeeded', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "var response = pm.response.json();",
              "pm.environment.set('token', response.token);"
            ]
          }
        }
      ]
    },
